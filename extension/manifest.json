
{
  "manifest_version": 3,
  "name": "Search Campaigns Helper",
  "version": "1.0",
  "description": "Chrome extension for managing search campaigns",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
