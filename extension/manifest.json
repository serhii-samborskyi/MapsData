
{
  "manifest_version": 3,
  "name": "Search Campaigns Helper",
  "version": "1.0",
  "description": "Chrome extension for managing search campaigns",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "http://0.0.0.0:8000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/maps/*"],
      "js": ["content.js"]
    }
  ]
}
